#!/usr/bin/env bash

WIDTH=20
DELAY=0.25

FRAMES=(
  "‚ĖĀ‚ĖÜ‚ĖĄ‚Ėą"
  "‚ĖÜ‚ĖĄ‚Ėą‚ĖĀ"
  "‚ĖĄ‚Ėą‚ĖĀ‚ĖÜ"
  "‚Ėą‚ĖĀ‚ĖÜ‚ĖĄ"
  "‚Ėā‚Ėą‚ĖÖ‚Ėá"
  "‚Ėą‚ĖÖ‚Ėá‚Ėā"
  "‚ĖÖ‚Ėá‚Ėā‚Ėą"
  "‚Ėá‚Ėā‚Ėą‚ĖÖ"
)

pos=0
frame_index=0

while true; do
  status=$(playerctl metadata --format '{{status}}' 2>/dev/null)
  title=$(playerctl metadata --format '{{title}} - {{artist}}' 2>/dev/null)

  if [ -z "$title" ] || [ "$status" != "Playing" ]; then
    echo ""
    sleep "$DELAY"
    continue
  fi

  frame="${FRAMES[$frame_index]}"
  frame_index=$(((frame_index + 1) % ${#FRAMES[@]}))

  text="$title   "
  len=${#text}

  if [ "$len" -le "$WIDTH" ]; then
    shown="$text"
  else
    doubled="$text$text"
    shown="${doubled:$pos:$WIDTH}"
    pos=$(((pos + 1) % len))
  fi

  printf "%s %-20.20s\n" "$frame" "$shown"

  sleep "$DELAY"
done
