#!/usr/bin/env bash
# $HOME/.local/bin/checkh
# @author: weiensong(touero) <touer0018@gmail.com>
# @since: 2026
# checkh: check md5 or sha256 of file

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

usage() {
  cat <<EOF
Usage:
  checkh <file> [file...]
  checkh <file> <hash>
  checkh <file> md5:<hash>
  checkh <file> sha256:<hash>

Examples:
  checkh app.apk
  checkh app.apk a7c4d9...
  checkh app.apk md5:d41d8cd98f00b204e9800998ecf8427e
  checkh app.apk sha256:93a719347dc2318b6b6356c588646a7ee82fd7ab0355e7a865fe6954de1234f0
EOF
  exit 1
}

[[ $# -lt 1 ]] && usage

is_hash() {
  [[ "$1" =~ ^[0-9a-fA-F]{32}$ ]] ||
    [[ "$1" =~ ^[0-9a-fA-F]{64}$ ]] ||
    [[ "$1" =~ ^md5:[0-9a-fA-F]{32}$ ]] ||
    [[ "$1" =~ ^sha256:[0-9a-fA-F]{64}$ ]]
}

show_hash() {
  local file="$1"

  if [[ ! -f "$file" ]]; then
    echo -e "${RED}Error:${NC} file not found: $file"
    return 1
  fi

  local md5 sha256

  md5=$(md5sum "$file" | awk '{print $1}')
  sha256=$(sha256sum "$file" | awk '{print $1}')

  echo -e "${YELLOW}==> $file${NC}"
  echo "MD5    : $md5"
  echo "SHA256 : $sha256"
  echo
}

verify_hash() {
  local file="$1"
  local input="$2"
  local expected actual algo

  [[ ! -f "$file" ]] && {
    echo -e "${RED}Error:${NC} file not found: $file"
    exit 1
  }

  input=$(echo "$input" | tr '[:upper:]' '[:lower:]')

  if [[ "$input" == md5:* ]]; then
    algo="MD5"
    expected="${input#md5:}"
    actual=$(md5sum "$file" | awk '{print $1}')

  elif [[ "$input" == sha256:* ]]; then
    algo="SHA256"
    expected="${input#sha256:}"
    actual=$(sha256sum "$file" | awk '{print $1}')

  else
    expected="$input"

    case ${#expected} in
    32)
      algo="MD5"
      actual=$(md5sum "$file" | awk '{print $1}')
      ;;
    64)
      algo="SHA256"
      actual=$(sha256sum "$file" | awk '{print $1}')
      ;;
    *)
      echo -e "${RED}Error:${NC} unsupported hash length (${#expected})"
      exit 1
      ;;
    esac
  fi

  if [[ "$actual" == "$expected" ]]; then
    echo -e "${GREEN}✓${NC} $algo matched"
  else
    echo -e "${RED}✗${NC} $algo mismatch"
    echo "Expected: $expected"
    echo "Actual  : $actual"
    exit 1
  fi
}

if [[ $# -eq 2 ]] && is_hash "$2"; then
  verify_hash "$1" "$2"
  exit 0
fi

for file in "$@"; do
  show_hash "$file"
done
